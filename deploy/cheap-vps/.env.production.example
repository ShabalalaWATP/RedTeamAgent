DOMAIN_NAME=redteamagent.co.uk www.redteamagent.co.uk
ACME_EMAIL=admin@redteamagent.co.uk
APP_ENV=production
APP_SECRET_KEY=replace-with-at-least-32-random-bytes
COOKIE_SECURE=true
CORS_ORIGINS=https://redteamagent.co.uk,https://www.redteamagent.co.uk
DAILY_REVIEW_RUN_LIMIT=20
LOGIN_RATE_LIMIT_PER_MINUTE=10
AUTH_EMAIL_RATE_LIMIT_PER_HOUR=6
AUTH_IP_RATE_LIMIT_PER_MINUTE=30
EXPENSIVE_RATE_LIMIT_PER_MINUTE=20
PUBLIC_APP_URL=https://redteamagent.co.uk
CAPTCHA_REQUIRED=false
TURNSTILE_SECRET_KEY=
VITE_TURNSTILE_SITE_KEY=
MFA_ISSUER=RedTeamAgent
ALLOW_FAKE_PROVIDER=true
SELF_HOSTED_PROVIDER_MODE=false
DATABASE_URL=postgresql+psycopg://redteam:replace-db-password@postgres:5432/redteam
POSTGRES_DB=redteam
POSTGRES_USER=redteam
POSTGRES_PASSWORD=replace-db-password
REDIS_URL=redis://redis:6379/0
S3_ENDPOINT_URL=http://minio:9000
S3_BUCKET=redteam-agent
S3_ACCESS_KEY_ID=replace-minio-user
S3_SECRET_ACCESS_KEY=replace-minio-password
MINIO_ROOT_USER=replace-minio-user
MINIO_ROOT_PASSWORD=replace-minio-password
VITE_API_BASE_URL=/api
MAIL_DELIVERY=smtp
MAIL_FROM=RedTeamAgent <noreply@redteamagent.co.uk>
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=replace-smtp-username
SMTP_PASSWORD=replace-smtp-password
SMTP_STARTTLS=true
