{
	email {$ACME_EMAIL}
}

{$DOMAIN_NAME} {
	encode zstd gzip

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(self), geolocation=()"
		Content-Security-Policy "default-src 'self'; connect-src 'self' https://challenges.cloudflare.com; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' https://challenges.cloudflare.com; frame-src https://challenges.cloudflare.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
	}

	handle_path /api/* {
		reverse_proxy api:8000 {
			header_up X-Real-IP {http.request.remote.host}
		}
	}

	reverse_proxy web:8080
}
